---
// The reading surface. A two-column sheet (body + margin) inside a masthead /
// footer frame, with the floating control bar. Zero client JS is required to
// read — the small inline script below only *enhances* (theme/reader/popups
// toggles). Fonts are self-hosted via Fontsource.
import '@fontsource/eb-garamond/400.css';
import '@fontsource/eb-garamond/500.css';
import '@fontsource/eb-garamond/400-italic.css';
import '@fontsource-variable/source-serif-4/opsz.css';
import '@fontsource-variable/source-serif-4/opsz-italic.css';
import '@fontsource-variable/source-sans-3/wght.css';
import '@fontsource-variable/jetbrains-mono/wght.css';
import '../styles/tokens.css';
import '../styles/global.css';

interface Crumb { label: string; href?: string; }
interface Props {
  title: string;
  crumbs?: Crumb[];
  readhint?: boolean;
}
const { title, crumbs = [], readhint = false } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — The Managed Child</title>
  <meta name="description" content="The Managed Child — a reference that shows its work. Visible validity in plain language." />
  {/* Set the theme class before first paint so there is no flash. No-JS keeps
      the OS preference (handled in tokens.css). */}
  <script is:inline>
    (function () {
      document.documentElement.classList.add('js');
      try {
        var t = localStorage.getItem('tmc-theme');
        if (t === 'dark' || t === 'light') document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    })();
  </script>
</head>
<body>
  <a class="skip-link" href="#main">Skip to reading</a>

  <header class="masthead">
    <a class="wordmark" href="/"><b>The Managed Child</b> &nbsp;<span>a reference in progress</span></a>
    {crumbs.length > 0 && (
      <nav class="crumbs" aria-label="Breadcrumb">
        {crumbs.map((c, i) => (
          <>
            {i > 0 && <span aria-hidden="true"> &nbsp;/&nbsp; </span>}
            {c.href ? <a href={c.href}>{c.label}</a> : <span class="here">{c.label}</span>}
          </>
        ))}
      </nav>
    )}
  </header>

  {readhint && (
    <p class="readhint"><b>How standing is marked.</b> Each entry carries a plain
    <em>certainty</em> word — <em>documented</em>, <em>possible</em>, or <em>apocryphal</em> —
    in the metadata line. The corner buttons toggle dark mode and reader mode.</p>
  )}

  <slot />

  <footer>
    <p class="legend-title">How standing is marked on this site</p>
    <dl class="legend">
      <div><dt>documented</dt><dd>Verifiable in the record — who wrote, met, funded, or said what. Survives a hostile reader.</dd></div>
      <div><dt>possible</dt><dd>A resemblance or suspected tie, legitimate to pursue but never cited as proof.</dd></div>
      <div><dt>apocryphal</dt><dd>Circulates as fact but traces to a fabricated or fictional source. Flagged so it never enters the foundation.</dd></div>
    </dl>
    <p class="colophon">The Managed Child · a reference that shows its work. Built to last.</p>
  </footer>

  <div class="controls" role="group" aria-label="Reading controls">
    <button class="ctrl" id="c-theme" type="button" aria-pressed="false"><span class="ci" aria-hidden="true">◐</span>dark</button>
    <button class="ctrl" id="c-reader" type="button" aria-pressed="false"><span class="ci" aria-hidden="true">▤</span>read</button>
  </div>

  <script is:inline>
    (function () {
      'use strict';
      var root = document.documentElement, body = document.body;
      var cTheme = document.getElementById('c-theme');
      var cReader = document.getElementById('c-reader');

      function currentTheme() {
        if (root.getAttribute('data-theme')) return root.getAttribute('data-theme');
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      function syncTheme() {
        var dark = currentTheme() === 'dark';
        cTheme.classList.toggle('active', dark);
        cTheme.setAttribute('aria-pressed', dark ? 'true' : 'false');
        cTheme.querySelector('.ci').textContent = dark ? '☾' : '◐';
      }
      cTheme.addEventListener('click', function () {
        var next = currentTheme() === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        try { localStorage.setItem('tmc-theme', next); } catch (e) {}
        syncTheme();
      });
      syncTheme();

      var readerOn = false;
      try { readerOn = localStorage.getItem('tmc-reader') === '1'; } catch (e) {}
      if (readerOn) body.classList.add('reader');
      cReader.classList.toggle('active', readerOn);
      cReader.setAttribute('aria-pressed', readerOn ? 'true' : 'false');
      cReader.addEventListener('click', function () {
        var on = body.classList.toggle('reader');
        cReader.classList.toggle('active', on);
        cReader.setAttribute('aria-pressed', on ? 'true' : 'false');
        try { localStorage.setItem('tmc-reader', on ? '1' : '0'); } catch (e) {}
      });
    })();
  </script>
</body>
</html>
