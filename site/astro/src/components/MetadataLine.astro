---
// The metadata line — the annotation header (§IV.6). Standing is rendered as a
// plain italic certainty word (the signature, §IV.16), hoverable for its
// definition; FRAME/PRINCIPLE nodes show a structural label and no claim.
import { standingFromGrade, nodeRegister, titleCase } from '../lib/certainty';

interface Props {
  grade: string;
  tags: string[];
  dates?: string;
  category?: string;
  mapNode?: string;
}
const { grade, tags, dates, category, mapNode } = Astro.props;
const standing = standingFromGrade(grade);
const register = nodeRegister(tags);
const hasDates = dates && dates !== '-';
---
<div class="meta">
  <span class="field">
    <span class="k">Standing</span>
    {standing.certainty ? (
      <span class="certainty" tabindex="0" data-def={standing.def} title={standing.def}>{standing.certainty}</span>
    ) : standing.structural ? (
      <span class="structural-label">{standing.structural}</span>
    ) : (
      <span class="v">—</span>
    )}
  </span>
  {register && (
    <span class="field"><span class="k">Register</span> <span class="v">{titleCase(register)}</span></span>
  )}
  {hasDates && (
    <span class="field"><span class="k">Dates</span> <span class="v">{dates}</span></span>
  )}
  {category && (
    <span class="field"><span class="k">Kind</span> <span class="v">{titleCase(category)}</span></span>
  )}
  {mapNode && (
    <span class="field"><span class="k">Map</span> <span class="v">{mapNode}</span></span>
  )}
</div>
{/* The certainty word carries its definition in a native `title` (works with JS
    disabled) and a `data-def` (the richer hover tooltip is wired in M3). The
    footer legend restates all three words, so meaning is never JS-dependent. */}
