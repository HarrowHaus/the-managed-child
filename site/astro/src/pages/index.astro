---
import { getCollection } from 'astro:content';
import Reading from '../layouts/Reading.astro';
import { standingFromGrade, titleCase } from '../lib/certainty';

const nodes = await getCollection('nodes', (n) => !standingFromGrade(n.data.grade).discarded);
const chapters = (await getCollection('chapters')).sort((a, b) => a.data.chapter - b.data.chapter);

// Group nodes by category, in a deliberate reading order.
const ORDER = ['concepts', 'people', 'works', 'institutions', 'events'] as const;
const byCategory = new Map<string, typeof nodes>();
for (const cat of ORDER) byCategory.set(cat, []);
for (const n of nodes) {
  const cat = n.data.category;
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(n);
}
for (const list of byCategory.values()) {
  list.sort((a, b) => a.data.title.localeCompare(b.data.title));
}
---
<Reading title="Reference" readhint={true}>
  <main class="sheet" id="main">
    <article class="body" style="grid-column: 1 / -1;">
      <p class="eyebrow">The Managed Child</p>
      <h1 class="node-title">A reference that shows its work</h1>
      <div class="index-intro">
        <p>An account of one impulse — <em>that humanity is administrable stock,
        to be graded and guided toward a planned end by an elect fit to do it</em>
        — tracked across a century, in bureaucratic prose and in myth alike.
        Every entry carries its standing in plain language: <em>documented</em>,
        <em>possible</em>, or <em>apocryphal</em>. Nothing is asserted past what
        the record supports.</p>
      </div>

      <section class="railset" id="book">
        <h2>The Book</h2>
        <ul class="node-list">
          {chapters.map((c) => (
            <li>
              <a href={`/book/${c.id}`}>{c.data.chapter}. {c.data.title}</a>
              {c.data.part && <span class="dates">{c.data.part}</span>}
            </li>
          ))}
        </ul>
      </section>

      {ORDER.map((cat) => {
        const list = byCategory.get(cat) ?? [];
        if (list.length === 0) return null;
        return (
          <section class="railset" id={cat}>
            <h2>{titleCase(cat)}</h2>
            <ul class="node-list">
              {list.map((n) => {
                const s = standingFromGrade(n.data.grade);
                return (
                  <li>
                    <a href={`/nodes/${n.data.id}`}>{n.data.title}</a>
                    {s.certainty && <span class="cert">{s.certainty}</span>}
                    {s.structural && <span class="cert">{s.structural}</span>}
                    {n.data.dates !== '-' && <span class="dates">{n.data.dates}</span>}
                  </li>
                );
              })}
            </ul>
          </section>
        );
      })}
    </article>
  </main>
</Reading>
