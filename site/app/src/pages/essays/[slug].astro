---
import { getCollection, render } from 'astro:content';
import GwernShell from '../../layouts/GwernShell.astro';
import { standingFromGrade } from '../../lib/certainty';
import { essayNeighbors } from '../../lib/essay-order';

// One page per essay ABOUT THE WORK. The stub index and anything under
// _parked-decodes are excluded (the latter by the collection glob). Essays are
// the inhabited voice with the apparatus stripped (CONVENTIONS §8): the page
// shows clean prose; its grounding nodes are linked (poppable) at the foot as
// the "receipts one hover away," never as visible grades.
export async function getStaticPaths() {
  const essays = (await getCollection('essays')).filter((e) => e.id !== 'index');
  const nodes = await getCollection('nodes', (n) => !standingFromGrade(n.data.grade).discarded);
  const byId = new Map(nodes.map((n) => [n.data.id, n.data.title]));
  // id → display title, so prev/next links can name the neighbouring essay.
  const essayTitles = new Map(essays.map((e) => [e.id, e.data.title as string]));
  return essays.map((essay) => ({ params: { slug: essay.id }, props: { essay, byId, essayTitles } }));
}

const { essay, byId, essayTitles } = Astro.props;
const d = essay.data;
const { Content } = await render(essay);
const { prev, next } = essayNeighbors(essay.id);
// Long Content, not a blog: the publication date stays in frontmatter for
// internal ordering but never renders (operator directive). No genre tag either
// — a reading entry is titled by its own title.
---
<GwernShell title={d.title}>
  <div slot="metadata" class="page-metadata-fields">
    {d.subtitle && <span class="page-description-inline"><em>{d.subtitle}</em></span>}
  </div>

  <Content />

  {d.grounding_nodes.length > 0 && (
    <section class="essay-grounding">
      <p><strong>Grounded in.</strong> The reference nodes underneath — hover to read each.</p>
      <ul>
        {d.grounding_nodes.map((id) => (
          byId.has(id) ? (
            <li><a class="link-page" href={`/nodes/${id}/`}>{byId.get(id)}</a></li>
          ) : (
            <li>{id}</li>
          )
        ))}
      </ul>
    </section>
  )}

  {/* Default prev/next follows this essay's PRIMARY reading; the reading-lens
      module re-threads it client-side to the selected reading. Rendered always
      (with the essay id) so JS can populate it even where the default is empty;
      hidden by CSS when it has no links and no reading is active. */}
  <nav
    class={`essay-nav${!prev && !next ? ' essay-nav-empty' : ''}`}
    aria-label="Reading order"
    data-essay-id={essay.id}
  >
    <span class="essay-nav-prev">
      {prev && (
        <a class="link-page" href={`/essays/${prev}`} rel="prev">
          ← <span class="essay-nav-label">{essayTitles.get(prev)}</span>
        </a>
      )}
    </span>
    <span class="essay-nav-position" hidden></span>
    <span class="essay-nav-next">
      {next && (
        <a class="link-page" href={`/essays/${next}`} rel="next">
          <span class="essay-nav-label">{essayTitles.get(next)}</span> →
        </a>
      )}
    </span>
  </nav>
</GwernShell>

<style>
  .essay-nav {
    display: flex;
    justify-content: space-between;
    gap: 1.5em;
    margin-top: 3em;
    padding-top: 1em;
    border-top: 1px solid var(--GW-body-text-color, currentColor);
    border-image: linear-gradient(to right, transparent, currentColor 20%, currentColor 80%, transparent) 1;
    font-variant: small-caps;
  }
  .essay-nav-next { margin-left: auto; text-align: right; }
  .essay-nav-label { font-variant: normal; }
  .essay-nav-empty { display: none; }
  .essay-nav-position { opacity: 0.6; font-size: 0.85em; align-self: center; }
</style>
