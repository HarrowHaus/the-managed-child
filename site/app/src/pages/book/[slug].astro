---
import { getCollection, render } from 'astro:content';
import GwernShell from '../../layouts/GwernShell.astro';
import { standingFromGrade } from '../../lib/certainty';

// One page per chapter. Demonstrates INLINE transclusion: each grounding node in
// `draws_on` is embedded via `<a class="include">`, which the forked transclude
// engine expands in place on load (recursive, composable).
export async function getStaticPaths() {
  const chapters = await getCollection('chapters');
  const nodes = await getCollection('nodes', (n) => !standingFromGrade(n.data.grade).discarded);
  const byId = new Map(nodes.map((n) => [n.data.id, n.data.title]));
  return chapters.map((chapter) => ({ params: { slug: chapter.id }, props: { chapter, byId } }));
}

const { chapter, byId } = Astro.props;
const d = chapter.data;
const { Content } = await render(chapter);
---
<GwernShell title={d.title}>
  <div slot="metadata" class="page-metadata-fields">
    {d.part && <span class="page-type">{d.part}</span>}
    <span class="page-status">chapter {d.chapter}</span>
    {d.register && <span class="page-register">register: <em>{d.register}</em></span>}
  </div>

  <Content />

  {d.draws_on.length > 0 && (
    <section class="draws-on">
      <p><strong>Draws on.</strong> The grounding nodes for this chapter, transcluded:</p>
      {d.draws_on.map((id) => (
        byId.has(id) ? (
          <div class="node-embed">
            {/* Inline transclusion: the forked transclude.js fetches /nodes/<id>
                and embeds its #markdownBody here on load. */}
            <a class="include include-strict" href={`/nodes/${id}/`}>{byId.get(id)}</a>
          </div>
        ) : (
          <p>{id}</p>
        )
      ))}
    </section>
  )}
</GwernShell>
