---
import { getCollection } from 'astro:content';
import GwernShell from '../layouts/GwernShell.astro';
import { standingFromGrade, titleCase } from '../lib/certainty';
import { essayRank } from '../lib/essay-order';

const nodes = await getCollection('nodes', (n) => !standingFromGrade(n.data.grade).discarded);
// Essays run in the canonical reading order (the guided thesis sequence), not by date.
const essays = (await getCollection('essays'))
  .filter((e) => e.id !== 'index')
  .sort((a, b) => essayRank(a.id) - essayRank(b.id));
const ORDER = ['concepts', 'people', 'works', 'institutions', 'events'] as const;
const byCat = new Map<string, typeof nodes>();
for (const c of ORDER) byCat.set(c, []);
for (const n of nodes) byCat.get(n.data.category)?.push(n);
for (const list of byCat.values()) list.sort((a, b) => a.data.title.localeCompare(b.data.title));
---
<GwernShell title="The Managed Child">
  <p>A reference that shows its work. Every entry links to the entries it leans
  on — hover any link to preview it, or read straight through. Standing is marked
  in plain language: <em>documented</em>, <em>possible</em>, <em>apocryphal</em>.</p>

  {essays.length > 0 && (
    <>
      <h2 id="essays">Essays</h2>
      <p>Read in order, the essays form one continuous argument. Start with
      <em> Two Testimonies</em> and read straight down, or step in anywhere.</p>
      <ol class="essay-sequence">
        {essays.map((e) => (
          <li>
            <a class="link-page" href={`/essays/${e.id}`}>{e.data.title}</a>
            {e.data.subtitle && <span> — <em>{e.data.subtitle}</em></span>}
          </li>
        ))}
      </ol>
    </>
  )}

  {ORDER.map((cat) => {
    const list = byCat.get(cat) ?? [];
    if (list.length === 0) return null;
    return (
      <>
        <h2 id={cat}>{titleCase(cat)}</h2>
        <ul>
          {list.map((n) => (
            <li><a class="link-page" href={`/nodes/${n.data.id}/`}>{n.data.title}</a></li>
          ))}
        </ul>
      </>
    );
  })}
</GwernShell>
