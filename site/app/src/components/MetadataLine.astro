---
// The node page-metadata line. A clean, label-free reading line:
//   [Category] · [register] · [dates] · [certainty-word]
//   e.g.  People · Enactment · 1891–1995 · documented
// NO field labels ("register:"/"certainty:") and NO internal drafting status
// (stub/drafted/locked) ever render — those are build-scaffolding (CLAUDE.md
// rule b). The certainty word stays hoverable for its definition; structural
// nodes (framework/principle) fill the same final slot without a label.
import { standingFromGrade, nodeRegister, titleCase } from '../lib/certainty';

interface Props {
  grade: string;
  tags?: string[];
  dates?: string;
  category?: string;
}
const { grade, tags = [], dates, category } = Astro.props;
const standing = standingFromGrade(grade);
const register = nodeRegister(tags);
const hasDates = dates && dates !== '-';
// en-dash for a date range (1891-1995 → 1891–1995); leave a single year as is.
const dateText = hasDates ? dates.replace(/(\d)\s*-\s*(\d)/, '$1–$2') : null;

// Leading plain-text parts, in order, labels stripped.
const parts = [
  category ? titleCase(category) : null,
  register ? titleCase(register) : null,
  dateText,
].filter(Boolean) as string[];
---
<div class="page-metadata-fields">
  {parts.map((p, i) => (
    <>
      {i > 0 && <span class="meta-sep"> · </span>}
      <span>{p}</span>
    </>
  ))}
  {(standing.certainty || standing.structural) && (
    <>
      {parts.length > 0 && <span class="meta-sep"> · </span>}
      {standing.certainty ? (
        <em class="certainty-word" tabindex="0" title={standing.def!}>{standing.certainty}</em>
      ) : (
        <em class="certainty-word">{standing.structural}</em>
      )}
    </>
  )}
</div>
